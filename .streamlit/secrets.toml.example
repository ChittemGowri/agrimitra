# For local development, use .env instead (see .env.example).
#
# This file is only needed when deploying to Streamlit Community Cloud.
# In the Streamlit Cloud dashboard: App settings -> Secrets -> paste:
#
# GEMINI_API_KEY = "your_key_here"
# DATA_GOV_API_KEY = ""
# OPENWEATHER_API_KEY = ""
#
# Do NOT commit a real secrets.toml file -- it's already in .gitignore.
