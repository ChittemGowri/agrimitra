# Copy this file to .env and fill in your real key:
#   cp .env.example .env
#
# Get a free NVIDIA API key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# Optional. Only needed if you want LIVE Indian govt mandi price data
# instead of the built-in realistic simulated baseline.
# Get a free key at: https://data.gov.in/
DATA_GOV_API_KEY=

# Optional. Only needed if you swap the weather tool to OpenWeatherMap
# instead of the default Open-Meteo (which needs no key at all).
OPENWEATHER_API_KEY=

# Optional: Base URL for NVIDIA NIM API (if different from default)
NVIDIA_BASE_URL=
